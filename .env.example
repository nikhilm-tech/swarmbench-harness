# Local-dev only. On a Codespace these are injected automatically via Settings → Codespaces → Secrets.
# Copy to `.env` and fill in real values:  cp .env.example .env
#
# Required: Fireworks API key (kimi-k2 inference)
FIREWORKS_API_KEY=fw-xxxxxxxxxxxx

# Preferred Kimi target (dedicated deployment). One of DEDICATED/SHARED is required.
# Example: fireworks_ai/accounts/<acct>/deployments/<id>
SWARM_MODEL_DEDICATED=

# Fallback Kimi target (serverless model)
# Example: fireworks_ai/accounts/fireworks/models/kimi-k2p5
SWARM_MODEL_SHARED=fireworks_ai/accounts/fireworks/models/kimi-k2p5
